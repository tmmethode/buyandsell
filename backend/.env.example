# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/rwanda_marketplace

# Server Configuration
PORT=5000
# development | production
NODE_ENV=development

# JWT Configuration
JWT_SECRET=replace_with_a_secure_random_secret
JWT_EXPIRE=30d

# File Upload Configuration
MAX_FILE_SIZE=5242880

# CORS Configuration
# Required in development when frontend runs on a different port (e.g., CRA dev server)
# Example: http://localhost:3000
# Optional in production when serving the React build from this backend (same-origin)
FRONTEND_URL=http://localhost:3000

# Google Cloud Storage (optional)
# Enable to store uploads in GCS instead of local filesystem.
# Current handover includes local uploads in backend/uploads, so these are optional.
# Required
# GCS_BUCKET_NAME=your-bucket-name
# Credentials: choose ONE of the following
# 1) Path to service account key file (absolute path)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# 2) Base64-encoded service account JSON
# GCS_SERVICE_ACCOUNT_JSON=base64_encoded_json
# Optional prefix to namespace objects (e.g., dev, prod)
# GCS_FOLDER_PREFIX=dev

# Signed contract email notifications (optional)
GMAIL_USER=
GMAIL_APP_PASSWORD=
SMTP_FROM_EMAIL=

# Alternative SMTP provider (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Contract notification recipients (optional but recommended)
CONTRACT_OWNER_EMAIL=
ADMIN_NOTIFICATION_EMAIL=
